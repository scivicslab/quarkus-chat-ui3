<?xml version="1.0"?>
<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd"
    xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <modelVersion>4.0.0</modelVersion>

  <groupId>com.scivicslab.chatui3</groupId>
  <artifactId>quarkus-chat-ui3</artifactId>
  <version>1.0.0-SNAPSHOT</version>
  <packaging>jar</packaging>

  <properties>
    <compiler-plugin.version>3.14.0</compiler-plugin.version>
    <maven.compiler.release>21</maven.compiler.release>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
    <quarkus.platform.artifact-id>quarkus-bom</quarkus.platform.artifact-id>
    <quarkus.platform.group-id>io.quarkus.platform</quarkus.platform.group-id>
    <quarkus.platform.version>3.28.3</quarkus.platform.version>
    <pojo-actor.version>3.5.0</pojo-actor.version>
    <turing-workflow.version>3.7.0</turing-workflow.version>
    <surefire-plugin.version>3.5.4</surefire-plugin.version>
    <!-- uber-jar: {artifactId}-{version}.jar, no -runner suffix -->
    <quarkus.package.jar.type>uber-jar</quarkus.package.jar.type>
    <quarkus.package.jar.add-runner-suffix>false</quarkus.package.jar.add-runner-suffix>
  </properties>

  <dependencyManagement>
    <dependencies>
      <dependency>
        <groupId>${quarkus.platform.group-id}</groupId>
        <artifactId>${quarkus.platform.artifact-id}</artifactId>
        <version>${quarkus.platform.version}</version>
        <type>pom</type>
        <scope>import</scope>
      </dependency>
    </dependencies>
  </dependencyManagement>

  <dependencies>
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-arc</artifactId>
    </dependency>
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-rest-jackson</artifactId>
    </dependency>
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-smallrye-health</artifactId>
    </dependency>
    <dependency>
      <groupId>com.scivicslab</groupId>
      <artifactId>pojo-actor</artifactId>
      <version>${pojo-actor.version}</version>
    </dependency>
    <!-- In-process agent loop (entry B): chat-ui3 embeds the Turing Workflow engine. -->
    <dependency>
      <groupId>com.scivicslab</groupId>
      <artifactId>turing-workflow</artifactId>
      <version>${turing-workflow.version}</version>
    </dependency>
    <!-- Complete LLM I/O logging (s_iolog): reuse the H2 log store + DatabaseAccumulator.
         Pinned to turing-workflow / pojo-actor versions matching this project. -->
    <dependency>
      <groupId>com.scivicslab.turingworkflow.plugins</groupId>
      <artifactId>plugin-log-db</artifactId>
      <version>1.6.0</version>
    </dependency>
    <!-- Workflow dispatch (known-task automation): the agent loop dispatches well-defined requests
         (understand a project / translate a document) to map-reduce Turing Workflows. Bundling these
         plugins puts their actor classes on the app classpath so the workflow's loader.createChild
         resolves them via Class.forName (robust under Quarkus, no runtime .m2 dependency). -->
    <dependency>
      <groupId>com.scivicslab.turingworkflow.plugins</groupId>
      <artifactId>plugin-codedoc</artifactId>
      <version>1.0.0</version>
    </dependency>
    <dependency>
      <groupId>com.scivicslab.turingworkflow.plugins</groupId>
      <artifactId>plugin-llm</artifactId>
      <version>1.5.0</version>
    </dependency>
    <!-- web_search tool: DuckDuckGo HTML scraping (same approach as the mcp-gateway / plugin-web tools).
         Only jsoup is needed; the search logic is a small confined helper, not the shaded plugin jar. -->
    <dependency>
      <groupId>org.jsoup</groupId>
      <artifactId>jsoup</artifactId>
      <version>1.18.3</version>
    </dependency>
    <dependency>
      <groupId>io.quarkus</groupId>
      <artifactId>quarkus-junit5</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>${quarkus.platform.group-id}</groupId>
        <artifactId>quarkus-maven-plugin</artifactId>
        <version>${quarkus.platform.version}</version>
        <extensions>true</extensions>
        <executions>
          <execution>
            <goals>
              <goal>build</goal>
              <goal>generate-code</goal>
              <goal>generate-code-tests</goal>
            </goals>
          </execution>
        </executions>
        <configuration>
          <jvmArgs>--add-opens java.base/java.lang=ALL-UNNAMED</jvmArgs>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>${compiler-plugin.version}</version>
        <configuration>
          <release>${maven.compiler.release}</release>
        </configuration>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <version>${surefire-plugin.version}</version>
        <configuration>
          <systemPropertyVariables>
            <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
          </systemPropertyVariables>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
